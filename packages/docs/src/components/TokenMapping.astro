---
export interface Props {
  tokens: { element: string; token: string; description?: string }[];
}

const { tokens } = Astro.props;
---

<div class="token-mapping">
  <div class="mapping-header">
    <div class="col">Target Element</div>
    <div class="col">Semantic Token</div>
    <div class="col desc">Implementation Detail</div>
  </div>
  {tokens.map((t) => (
    <div class="mapping-row">
      <div class="col target"><code>{t.element}</code></div>
      <div class="col token">
        <code>{t.token}</code>
      </div>
      <div class="col desc">{t.description}</div>
    </div>
  ))}
</div>

<style>
  .token-mapping {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--sl-color-hairline, var(--sl-color-gray-5));
    border-radius: 8px;
    background: var(--sl-color-black);
    margin: 1.5rem 0;
    overflow: hidden;
  }
  .mapping-header {
    display: flex;
    background: var(--sl-color-gray-6);
    padding: 0.75rem 1.25rem;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--sl-color-white);
    border-bottom: 1px solid var(--sl-color-hairline, var(--sl-color-gray-5));
  }
  .mapping-row {
    display: flex;
    padding: 1rem 1.25rem;
    border-bottom: 1px solid var(--sl-color-hairline, var(--sl-color-gray-5));
    align-items: center;
    gap: 1rem;
  }
  .mapping-row:last-child {
    border-bottom: none;
  }
  .col {
    flex: 1;
    font-size: 0.85rem;
  }
  .col.desc {
    flex: 1.5;
    color: var(--sl-color-gray-2);
    line-height: 1.5;
  }
  .target code {
    background: var(--sl-color-gray-6);
    color: var(--sl-color-accent);
    padding: 0.2rem 0.4rem;
    border-radius: 4px;
    font-weight: 600;
  }
  .token code {
    background: transparent;
    color: var(--sl-color-gray-1);
    font-size: 0.8rem;
    border: 1px solid var(--sl-color-gray-5);
  }
</style>
