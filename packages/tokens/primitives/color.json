{
  "$description": "Nirman Design System — Primitive Tokens: Color. Raw values derived from the existing design language. Never used directly by components. Prefix: nir-",
  "color": {
    "$description": "Complete color palette. Source: existing Figma global variables, extended with tint/shade ramps for theming and accessibility modes.",

    "navy": {
      "$description": "Primary brand range. Base: #083459",
      "50":  { "$value": "#E6EDF3", "$type": "color" },
      "100": { "$value": "#CED6DE", "$type": "color", "$description": "Matches existing primary/very-light" },
      "200": { "$value": "#8298AA", "$type": "color", "$description": "Matches existing surface/container-light" },
      "300": { "$value": "#5B7A94", "$type": "color" },
      "400": { "$value": "#3A5D7A", "$type": "color" },
      "500": { "$value": "#0B4A78", "$type": "color" },
      "600": { "$value": "#083459", "$type": "color", "$description": "PRIMARY BASE — matches existing primary/base" },
      "700": { "$value": "#062A48", "$type": "color" },
      "800": { "$value": "#041E34", "$type": "color" },
      "900": { "$value": "#010F2A", "$type": "color", "$description": "Matches existing surface/on-base" },
      "950": { "$value": "#010A1C", "$type": "color" }
    },

    "ink": {
