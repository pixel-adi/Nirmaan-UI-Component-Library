{
  "$description": "Component-level semantic tokens. These map component needs to the semantic spacing/radius scale. Use these in component CSS for clearer intent and easier Figma handoff.",
  "component": {
    "button": {
      "padding-x": {
        "sm": { "$value": "{spacing.component-padding-sm}", "$type": "dimension" },
        "md": { "$value": "{spacing.component-padding-md}", "$type": "dimension" },
        "lg": { "$value": "{spacing.component-padding-lg}", "$type": "dimension" }
      },
      "padding-y": {
        "sm": { "$value": "{spacing.component-padding-xs}", "$type": "dimension" },
        "md": { "$value": "{spacing.component-padding-sm}", "$type": "dimension" },
        "lg": { "$value": "{spacing.component-padding-md}", "$type": "dimension" }
      },
      "gap": {
        "$value": "{spacing.inline-xs}",
        "$type": "dimension",
        "$description": "Gap between icon and label"
      },
      "radius": {
        "$value": "{radius.interactive}",
        "$type": "dimension"
      },
      "height": {
        "sm": { "$value": "36px", "$type": "dimension" },
        "md": { "$value": "44px", "$type": "dimension", "$description": "WCAG 2.5.8 touch target" },
        "lg": { "$value": "52px", "$type": "dimension" }
      }
    },
    "input": {
      "padding-x": {
        "sm": { "$value": "{spacing.component-padding-sm}", "$type": "dimension" },
        "md": { "$value": "{spacing.component-padding-md}", "$type": "dimension" },
        "lg": { "$value": "{spacing.component-padding-lg}", "$type": "dimension" }
      },
      "padding-y": {
        "sm": { "$value": "{spacing.component-padding-xs}", "$type": "dimension" },
        "md": { "$value": "{spacing.component-padding-sm}", "$type": "dimension" },
        "lg": { "$value": "{spacing.component-padding-md}", "$type": "dimension" }
      },
      "radius": {
        "$value": "{radius.interactive}",
        "$type": "dimension"
      },
      "height": {
        "sm": { "$value": "36px", "$type": "dimension" },
        "md": { "$value": "44px", "$type": "dimension" },
        "lg": { "$value": "52px", "$type": "dimension" }
      },
      "label-gap": {
        "$value": "{spacing.stack-xs}",
        "$type": "dimension",
        "$description": "Gap between label and field"
      },
      "helper-gap": {
        "$value": "{spacing.stack-xs}",
        "$type": "dimension",
        "$description": "Gap between field and helper text"
      }
    },
    "checkbox": {
      "size": {
        "sm": { "$value": "16px", "$type": "dimension" },
        "md": { "$value": "20px", "$type": "dimension" }
      },
      "radius": {
        "$value": "{radius.xs}",
        "$type": "dimension"
      },
      "label-gap": {
        "$value": "{spacing.inline-sm}",
        "$type": "dimension"
      }
    },
    "radio": {
      "size": {
        "sm": { "$value": "16px", "$type": "dimension" },
        "md": { "$value": "20px", "$type": "dimension" }
      },
      "radius": {
        "$value": "{radius.full}",
        "$type": "dimension"
      },
      "label-gap": {
        "$value": "{spacing.inline-sm}",
        "$type": "dimension"
      },
      "group-gap": {
        "$value": "{spacing.stack-sm}",
        "$type": "dimension"
      }
    },
    "toggle": {
      "track": {
        "width": {
          "sm": { "$value": "32px", "$type": "dimension" },
          "md": { "$value": "44px", "$type": "dimension" }
        },
        "height": {
          "sm": { "$value": "18px", "$type": "dimension" },
          "md": { "$value": "24px", "$type": "dimension" }
        }
      },
      "thumb": {
        "size": {
          "sm": { "$value": "14px", "$type": "dimension" },
          "md": { "$value": "20px", "$type": "dimension" }
        }
      },
      "radius": {
        "$value": "{radius.full}",
        "$type": "dimension"
      },
      "label-gap": {
        "$value": "{spacing.inline-sm}",
        "$type": "dimension"
      }
    },
    "dropdown": {
      "padding-x": {
        "$value": "{spacing.component-padding-md}",
        "$type": "dimension"
      },
      "padding-y": {
        "$value": "{spacing.component-padding-sm}",
        "$type": "dimension"
      },
      "radius": {
        "$value": "{radius.interactive}",
        "$type": "dimension"
      },
      "menu-radius": {
        "$value": "{radius.container}",
        "$type": "dimension"
      },
      "menu-padding": {
        "$value": "{spacing.component-padding-xs}",
        "$type": "dimension"
      },
      "menu-item-padding-x": {
        "$value": "{spacing.component-padding-md}",
        "$type": "dimension"
      },
      "menu-item-padding-y": {
        "$value": "{spacing.component-padding-sm}",
        "$type": "dimension"
      },
      "menu-offset": {
        "$value": "{spacing.stack-xs}",
        "$type": "dimension",
        "$description": "Gap between trigger and menu"
      }
    },
    "card": {
      "padding": {
        "sm": { "$value": "{spacing.component-padding-md}", "$type": "dimension" },
        "md": { "$value": "{spacing.component-padding-lg}", "$type": "dimension" },
        "lg": { "$value": "32px", "$type": "dimension" }
      },
      "radius": {
        "$value": "{radius.container}",
        "$type": "dimension"
      },
      "gap": {
        "$value": "{spacing.stack-md}",
        "$type": "dimension"
      }
    },
    "modal": {
      "padding": {
        "$value": "{spacing.component-padding-lg}",
        "$type": "dimension"
      },
      "radius": {
        "$value": "{radius.lg}",
        "$type": "dimension"
      },
      "max-width": {
        "sm": { "$value": "400px", "$type": "dimension" },
        "md": { "$value": "600px", "$type": "dimension" },
        "lg": { "$value": "900px", "$type": "dimension" }
      }
    },
    "tag": {
      "padding-x": {
        "$value": "{spacing.component-padding-sm}",
        "$type": "dimension"
      },
      "padding-y": {
        "$value": "2px",
        "$type": "dimension"
      },
      "radius": {
        "$value": "{radius.pill}",
        "$type": "dimension"
      },
      "gap": {
        "$value": "{spacing.inline-xs}",
        "$type": "dimension"
      }
    }
  }
}
